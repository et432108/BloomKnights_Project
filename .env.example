# ---------------------------------------------------------------------------
# BloomKnights environment
# Copy to .env and fill in. Client-safe Firebase values are ALSO mirrored into
# app.json > expo.extra so they are bundled at build time.
# ---------------------------------------------------------------------------

# Firebase client config (safe to ship — protected by Firestore rules)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google OAuth client IDs (expo-auth-session)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# ---------------------------------------------------------------------------
# SERVER-ONLY. Never bundle into the app. Set via:
#   firebase functions:secrets:set GEMINI_API_KEY
# Listed here for documentation only.
# ---------------------------------------------------------------------------
# GEMINI_API_KEY=
