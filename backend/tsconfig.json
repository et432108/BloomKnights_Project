{
  "compilerOptions": {
    "module": "node16",
    "target": "es2021",
    "moduleResolution": "node16",
    "outDir": "lib",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/__tests__/**"]
}
