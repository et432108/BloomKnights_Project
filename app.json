{
  "expo": {
    "name": "BloomKnights",
    "slug": "bloomknights",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bloomknights",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bloomknights.app"
    },
    "android": {
      "package": "com.bloomknights.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "firebaseApiKey": "",
      "firebaseAuthDomain": "",
      "firebaseProjectId": "",
      "firebaseStorageBucket": "",
      "firebaseMessagingSenderId": "",
      "firebaseAppId": "",
      "googleWebClientId": "",
      "googleIosClientId": "",
      "googleAndroidClientId": ""
    }
  }
}
